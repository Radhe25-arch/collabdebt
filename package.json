{
  "name": "codearena",
  "version": "1.0.0",
  "private": true,
  "description": "CodeArena — Free gamified coding platform",
  "scripts": {
    "dev":          "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server":   "cd server && npm run dev",
    "dev:client":   "cd client && npm run dev",
    "build":        "npm install --prefix client && npm run build --prefix client",
    "vercel-build": "npm install --prefix client && npm run build --prefix client",
    "install:all":  "npm run install:server && npm run install:client",
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install",
    "db:migrate":   "cd server && npx prisma migrate dev",
    "db:seed":      "cd server && node prisma/seed.js",
    "db:studio":    "cd server && npx prisma studio",
    "docker:up":    "docker-compose up -d",
    "docker:down":  "docker-compose down",
    "docker:logs":  "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
