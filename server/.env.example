# ════════════════════════════════════════════════════════════
#  CodeArena — Server Environment Variables
#  Copy to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ─── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ─── DATABASE ─────────────────────────────────────────────
# Option A: Local PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/codearena?schema=public"

# Option B: Supabase (recommended for production)
# 1. Go to https://supabase.com → New Project
# 2. Settings → Database → Connection string → URI (use the "pooler" URL for serverless)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Use this for migrations (direct connection, not pooler):
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# Option C: Railway PostgreSQL
# DATABASE_URL="postgresql://postgres:[password]@[host].railway.app:5432/railway"

# ─── REDIS ────────────────────────────────────────────────
# Option A: Local Redis
REDIS_URL=redis://localhost:6379

# Option B: Upstash Redis (serverless-friendly, free tier available)
# 1. Go to https://upstash.com → Create Database → Redis
# 2. Copy the "UPSTASH_REDIS_REST_URL" and use it here
# REDIS_URL=rediss://:[password]@[endpoint].upstash.io:6379

# Option C: Railway Redis
# REDIS_URL=redis://:[password]@[host].railway.app:6379

# ─── JWT SECRETS ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── GOOGLE OAUTH (optional) ──────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Authorized redirect URIs: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── EMAIL / SMTP (optional but recommended) ──────────────
# Option A: Gmail (free)
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="CodeArena <noreply@codearena.dev>"

# Option B: Resend (recommended — 100 emails/day free)
# 1. Go to https://resend.com → API Keys → Create Key
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_resend_api_key

# Option C: Brevo (formerly Sendinblue — 300 emails/day free)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_brevo_smtp_key

# Required for Prisma migrations when using Supabase pooler URL above
# Use the direct connection string (NOT the pooler one)
# Leave empty / comment out if using direct DATABASE_URL
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.com:5432/postgres"
