// SkillForge — Full PostgreSQL Schema via Prisma ORM
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Required when using Supabase connection pooler (pgbouncer)
  // Comment out if using direct connection
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  STUDENT
  PROFESSIONAL
  BEGINNER
  ADMIN
}

enum AgeGroup {
  SCHOOL
  COLLEGE
  WORKING
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TournamentType {
  CODING_CHALLENGE
  QUIZ_BATTLE
  SPEED_COURSE
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  ENDED
}

enum NotificationType {
  STREAK_REMINDER
  LEVEL_UP
  BADGE_AWARDED
  TOURNAMENT_START
  TOURNAMENT_END
  WEEKLY_SUMMARY
  NEW_COURSE
  BATTLE_INVITE
  BATTLE_ACCEPTED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
}

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

// ─── USER ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  fullName      String
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  bio           String?
  role          Role      @default(STUDENT)
  ageGroup      AgeGroup  @default(COLLEGE)

  // Gamification
  xp            Int       @default(0)
  level         Int       @default(1)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime?

  // Stats
  totalQuizAttempts   Int @default(0)
  correctQuizAnswers  Int @default(0)
  coursesCompleted    Int @default(0)

  // Flags
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  onboarded     Boolean   @default(false)

  // AI Mentor Limits
  mentorRequests     Int       @default(0)
  lastMentorRequestAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  interests         UserInterest[]
  enrollments       Enrollment[]
  lessonProgress    LessonProgress[]
  quizAttempts      QuizAttempt[]
  badges            UserBadge[]
  tournamentEntries TournamentEntry[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  following         Follow[]  @relation("Follower")
  followers         Follow[]  @relation("Following")
  xpTransactions    XPTransaction[]

  // New feature relations
  battlesAsChallenger Battle[]          @relation("BattleChallenger")
  battlesAsChallenged Battle[]          @relation("BattleChallenged")
  battleSubmissions   BattleSubmission[] @relation("BattleSubmissions")
  questCompletions    QuestCompletion[] @relation("QuestCompletions")
  portfolio           Portfolio?        @relation("UserPortfolio")
  mentorSessions      MentorSession[]   @relation("MentorSessions")
  codeRoomsOwned      CodeRoom[]        @relation("CodeRoomOwner")
  codeRoomsJoined     CodeRoomParticipant[] @relation("CodeRoomParticipant")
  skillDNA            SkillDNA?         @relation("SkillDNA")

  friendshipsSent     Friendship[]      @relation("FriendshipSender")
  friendshipsReceived Friendship[]      @relation("FriendshipReceiver")

  sentMessages        Message[]         @relation("SentMessages")
  receivedMessages    Message[]         @relation("ReceivedMessages")

  @@index([xp])
  @@index([username])
}

model UserInterest {
  id       String @id @default(cuid())
  userId   String
  category String // web_dev, dsa, python, javascript, mobile, aiml
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── AUTH ─────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  otp       String
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── COURSES ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconName    String?  // icon key for frontend
  order       Int      @default(0)
  courses     Course[]
}

model Course {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  thumbnail   String?
  difficulty  Difficulty @default(BEGINNER)
  xpReward    Int        @default(200)
  duration    Int        @default(0) // minutes
  isPublished Boolean    @default(false)
  order       Int        @default(0)

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])

  lessons     Lesson[]
  enrollments Enrollment[]
  badge       Badge?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String   // Markdown content
  videoUrl    String?
  codeStarter String?  // Starter code for embedded editor
  xpReward    Int      @default(50)
  order       Int      @default(0)
  duration    Int      @default(0) // minutes

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  quiz        Quiz?
  progress    LessonProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, slug])
  @@index([courseId])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  completedAt DateTime?
  progress    Int       @default(0) // 0-100 percent
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── QUIZ ─────────────────────────────────────────────────

model Quiz {
  id        String         @id @default(cuid())
  lessonId  String         @unique
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  question      String
  options       Json     // string[]
  correctIndex  Int
  explanation   String?
  order         Int      @default(0)

  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int      // correct answers count
  total     Int      // total questions
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

// ─── GAMIFICATION ─────────────────────────────────────────

model XPTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String   // lesson_complete, quiz_pass, tournament_win, streak_bonus, etc.
  refId     String?  // ID of related entity
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  xpEarned  Int      @default(0)
  lessons   Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ─── BADGES ───────────────────────────────────────────────

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconName    String
  rarity      String      @default("common") // common, rare, epic, legendary
  courseId    String?     @unique            // if course-completion badge
  course      Course?     @relation(fields: [courseId], references: [id])
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// ─── TOURNAMENTS ──────────────────────────────────────────

model Tournament {
  id          String           @id @default(cuid())
  title       String
  weekNumber  Int
  type        TournamentType
  status      TournamentStatus @default(UPCOMING)
  startsAt    DateTime
  endsAt      DateTime
  xpBonus     Int              @default(500)
  description String?

  entries     TournamentEntry[]
  submissions TournamentSubmission[]

  createdAt   DateTime @default(now())

  @@index([status])
  @@index([startsAt])
}

model TournamentEntry {
  id           String     @id @default(cuid())
  userId       String
  tournamentId String
  score        Int        @default(0)
  rank         Int?
  joinedAt     DateTime   @default(now())
  rewarded     Boolean    @default(false)

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([tournamentId, score])
}

model TournamentSubmission {
  id           String     @id @default(cuid())
  userId       String
  tournamentId String
  code         String?
  language     String?
  score        Int        @default(0)
  timeTaken    Int?       // seconds
  submittedAt  DateTime   @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

// ─── NOTIFICATIONS ────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── HALL OF FAME ─────────────────────────────────────────

model HallOfFame {
  id         String   @id @default(cuid())
  userId     String
  username   String
  avatarUrl  String?
  xp         Int
  rank       Int      // 1, 2, or 3
  weekNumber Int
  year       Int
  awardedAt  DateTime @default(now())

  @@unique([weekNumber, year, rank])
  @@index([weekNumber, year])
}

// ─── 1v1 BATTLE ───────────────────────────────────────────

enum BattleStatus {
  PENDING
  CONFIGURING
  ACTIVE
  COMPLETED
  DECLINED
  EXPIRED
}

model Battle {
  id           String       @id @default(cuid())
  challengerId String
  challengedId String
  status       BattleStatus @default(PENDING)
  problemId    String?
  mode         String       @default("system") // system vs custom
  language     String       @default("javascript")
  problemText  String?
  codeStarter  String?
  timeLimit    Int          @default(1800) // seconds — 30 min default
  startsAt     DateTime?
  endsAt       DateTime?
  winnerId     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  challenger   User         @relation("BattleChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged   User         @relation("BattleChallenged", fields: [challengedId], references: [id], onDelete: Cascade)
  submissions  BattleSubmission[]
  report       BattleReport?

  @@index([challengerId])
  @@index([challengedId])
  @@index([status])
}

model BattleSubmission {
  id          String   @id @default(cuid())
  battleId    String
  userId      String
  code        String
  language    String   @default("javascript")
  passed      Int      @default(0)   // test cases passed
  total       Int      @default(0)   // total test cases
  timeTaken   Int?     // ms
  memoryUsed  Int?     // KB
  submittedAt DateTime @default(now())
  attempt     Int      @default(1)

  battle      Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user        User     @relation("BattleSubmissions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([battleId])
  @@index([userId])
}

model BattleReport {
  id              String   @id @default(cuid())
  battleId        String   @unique
  winnerId        String?
  challengerScore Json     // { accuracy, avgTime, attempts, testsPassed, weakTopics[] }
  challengedScore Json
  analysis        String?  // AI-generated analysis text
  generatedAt     DateTime @default(now())

  battle          Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
}

// ─── DAILY QUEST ──────────────────────────────────────────

enum QuestType {
  LESSON_COMPLETE
  QUIZ_PASS
  CODE_SOLVE
  STREAK_MAINTAIN
  COURSE_ENROLL
  TOURNAMENT_JOIN
}

enum QuestDifficulty {
  EASY
  MEDIUM
  HARD
}

model DailyQuest {
  id          String          @id @default(cuid())
  date        DateTime        // the day this quest is for (00:00:00 UTC)
  title       String
  description String
  type        QuestType
  target      Int             @default(1)
  xpReward    Int             @default(100)
  difficulty  QuestDifficulty @default(EASY)
  metadata    Json?           // e.g. { categorySlug: 'python' }

  completions QuestCompletion[]

  @@unique([date, type])
  @@index([date])
}

model QuestCompletion {
  id        String     @id @default(cuid())
  userId    String
  questId   String
  progress  Int        @default(0)
  completed Boolean    @default(false)
  completedAt DateTime?
  xpAwarded Int        @default(0)
  createdAt DateTime   @default(now())

  user      User       @relation("QuestCompletions", fields: [userId], references: [id], onDelete: Cascade)
  quest     DailyQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
}

// ─── GITHUB PORTFOLIO ─────────────────────────────────────

model Portfolio {
  id              String   @id @default(cuid())
  userId          String   @unique
  githubUsername  String?
  githubToken     String?  // encrypted PAT for repo creation
  repoName        String?
  repoUrl         String?
  lastBuiltAt     DateTime?
  autoSync        Boolean  @default(true)
  customDomain    String?
  themeColor      String   @default("#7C3AED")
  bio             String?
  skills          Json?    // string[]
  socialLinks     Json?    // { github, linkedin, twitter, website }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("UserPortfolio", fields: [userId], references: [id], onDelete: Cascade)
  projects        PortfolioProject[]
}

model PortfolioProject {
  id          String   @id @default(cuid())
  portfolioId String
  title       String
  description String?
  language    String?
  code        String?  // saved code from lessons/battles
  tags        Json?    // string[]
  repoUrl     String?
  liveUrl     String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
}

// ─── AI CODE MENTOR ───────────────────────────────────────

model MentorSession {
  id        String   @id @default(cuid())
  userId    String
  topic     String?
  messages  Json     // { role, content, timestamp }[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("MentorSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── CODE ROOMS (Collaborative) ───────────────────────────

model CodeRoom {
  id          String   @id @default(cuid())
  name        String
  code        String   @default("")
  language    String   @default("javascript")
  ownerId     String
  isPublic    Boolean  @default(false)
  maxUsers    Int      @default(4)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  owner       User     @relation("CodeRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  participants CodeRoomParticipant[]

  @@index([ownerId])
}

model CodeRoomParticipant {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  joinedAt   DateTime @default(now())
  cursorPos  Int      @default(0)

  room       CodeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation("CodeRoomParticipant", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

// ─── SKILL DNA ────────────────────────────────────────────

model SkillDNA {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json     // { category: { score, trend, weakTopics[], strongTopics[] } }
  updatedAt DateTime @updatedAt

  user      User     @relation("SkillDNA", fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String       @id @default(cuid())
  senderId    String
  receiverId  String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sender      User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver    User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)

  sender      User     @relation("SentMessages",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([createdAt])
}
